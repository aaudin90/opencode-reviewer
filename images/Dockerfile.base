FROM golang:1.26-bookworm AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o /app/build/opencode-reviewer ./cmd/reviewer

FROM almalinux:9-minimal

RUN microdnf install -y git ca-certificates tar net-tools && microdnf clean all

ARG TARGETARCH
RUN case "${TARGETARCH}" in \
    amd64) ARCH=x64 ;; \
    arm64) ARCH=arm64 ;; \
    *) echo "Unsupported arch: ${TARGETARCH}" && exit 1 ;; \
  esac && \
  curl -fsSL "https://github.com/anomalyco/opencode/releases/download/v1.2.27/opencode-linux-${ARCH}.tar.gz" \
    | tar -xzC /usr/local/bin && \
  chmod +x /usr/local/bin/opencode

COPY --from=builder /app/build/opencode-reviewer /usr/local/bin/opencode-reviewer

ENV OPENCODE_DISABLE_AUTOUPDATE=true \
    OPENCODE_DISABLE_MODELS_FETCH=true \
    OPENCODE_DISABLE_DEFAULT_PLUGINS=true \
    OPENCODE_DISABLE_LSP_DOWNLOAD=true

RUN mkdir -p /project

WORKDIR /project
